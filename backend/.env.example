# Server Configuration
PORT=3001
HOST=0.0.0.0

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Storage — all data lives under DATA_DIR so it is captured by ZIP backups
# UPLOAD_DIR is intentionally inside DATA_DIR (./data/uploads)
UPLOAD_DIR=./data/uploads
DATA_DIR=./data

# File Retention Policy
MAX_VERSIONS_PER_FILE=10
MAX_RETENTION_DAYS=365

# Admin default credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_DISPLAY_NAME=Administrator

# CORS - comma-separated list of allowed origins (leave empty to allow all local)
CORS_ORIGINS=

# Directory-based incremental backup (used by admin UI restore)
BACKUP_DIR=./data/backups
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION=7

# Weekly ZIP export — every 7 days a full ZIP of the data directory is written
# to ZIP_BACKUP_DIR.  Set this to an absolute path OUTSIDE the project folder
# so that the ZIP files survive when the project is updated/replaced.
# Example (Windows): ZIP_BACKUP_DIR=C:\VonikoBackups
# Example (Linux):   ZIP_BACKUP_DIR=/var/voniko_backups
# If left empty the default ./data/zip_backups is used (still inside data).
ZIP_BACKUP_DIR=./data/zip_backups
# Cron schedule for ZIP export (default: every Sunday at 04:00)
ZIP_BACKUP_SCHEDULE=0 4 * * 0
# How many ZIP files to keep (older ones are deleted automatically)
ZIP_BACKUP_RETENTION=4

# How many days MDB cache files (DM2000/DMP copies) are kept without being
# refreshed before they are removed by the nightly cleanup job (default: 365)
CACHE_RETENTION_DAYS=365

# Battery Service (Python FastAPI on port 8765)
BATTERY_SERVICE_URL=http://127.0.0.1:8765

# Count Batteries AI Service (Python FastAPI on port 8001)
COUNT_BATTERIES_URL=http://127.0.0.1:8001
COUNT_BATTERIES_TIMEOUT_MS=120000

# DMP Battery Data Bridge
DMP_MDB_DIR=C:\DMP\Data
DMP_TEMPLATES_DIR=./src/assets/dmp_templates

# DM2000 Historic Database
DM2000_DATA_DIR=D:\DM2000\dmdatabase
DM2000_TEMPLATES_DIR=./src/assets/dm2000_templates

# DMP/DM2000 local cache directories (written by dmp-services, read by backend)
# Paths are relative to the dmp-services working directory by default.
# DM2000_CACHE_DIR=../backend/data/dm2000_cache
# DMPDATA_CACHE_DIR=../backend/data/dmpdata_cache
